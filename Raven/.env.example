# RAVEN — Environment Variables
# Copy this file to .env and fill in the values before starting the server.
# .env is gitignored and must never be committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Master API key. All API calls require a valid key.
# Generate with: python -c "import secrets; print('raven_' + secrets.token_hex(24))"
RAVEN_API_KEY=raven-production-key

# ── Authentication ─────────────────────────────────────────────────────────────

# Beta key registry (compact JSON). Populated by manage_beta.py generate.
# Format: {"<key>": {"name": "Tester Name", "status": "active", "created_at": "ISO8601"}}
BETA_KEYS_JSON=

# Additional comma-separated free-tier API keys (optional).
FREE_API_KEYS=raven-free-test-key

# Additional comma-separated pro-tier API keys (optional).
PRO_API_KEYS=raven-production-key

# ── Server ────────────────────────────────────────────────────────────────────

PORT=8000
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated allowed CORS origins. Use * only in development.
CORS_ORIGINS=*

# "development" or "production"
ENVIRONMENT=development

# ── Sentinel pipeline ─────────────────────────────────────────────────────────

# Maximum number of events held in the async ingestion buffer.
SENTINEL_BUFFER_MAXSIZE=1000

# Buffer backpressure policy: DROP_NEWEST (default) or BLOCK.
# DROP_NEWEST returns HTTP 429 when the buffer is full.
# BLOCK suspends ingestion until space is available.
SENTINEL_BUFFER_POLICY=DROP_NEWEST

# Signal deduplication window: max events to track.
SENTINEL_WINDOW_MAXLEN=5000

# Signal deduplication window: time-to-live in seconds (default 1 hour).
SENTINEL_WINDOW_TTL=3600

# Optional webhook URL for action notifications (POST, JSON body).
SENTINEL_WEBHOOK_URL=

# ── Storage ───────────────────────────────────────────────────────────────────

# Directory for runtime data files (telemetry, decision logs).
# Relative paths are resolved from the server working directory.
RAVEN_DATA_DIR=data

# ── Debug (development only) ──────────────────────────────────────────────────

# Set to "1" to enable debug scoring output in API responses.
SENTINEL_DEBUG=

# Set to "1" to enable strict mode (rejects events that fail schema validation).
SENTINEL_STRICT_MODE=
